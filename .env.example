# DVSA Credentials
DVSA_LICENCE_NUMBER=your_licence_number
DVSA_TEST_REF=your_booking_reference

# Date thresholds (YYYY-MM-DD)
CURRENT_TEST_DATE=2025-09-15
EARLIEST_ACCEPTABLE=2025-06-01

# Captcha solvers (at least one required)
# CapSolver (AI-powered, fastest) — https://www.capsolver.com/
CAPSOLVER_API_KEY=
# 2Captcha (human workers, reliable fallback) — https://2captcha.com/
TWOCAPTCHA_API_KEY=

# Brevo email notifications — https://www.brevo.com/
BREVO_API_KEY=your_brevo_api_key
NOTIFY_EMAIL=you@example.com
FROM_EMAIL=notifier@yourdomain.com

# Dashboard
FLASK_SECRET=change_this_to_random_string
FLASK_PORT=5050

# Browser: HEADLESS=false is STRONGLY recommended — headless Chrome has
# detectable differences in plugins, canvas, audio context, and screen
# dimensions that Imperva's reese84 challenge flags as bot traffic.
# Only use true on headless systems (Pi) with Xvfb providing a virtual display.
HEADLESS=false

# Clear browser profiles on each scheduler start to remove stale cookies
# Set to false if you want to preserve profiles across restarts
CLEAR_PROFILES_ON_START=true

# Capture network traffic as HAR files in logs/ (for debugging Imperva issues)
# Open in Chrome DevTools → Network → Import, or any HAR viewer
CAPTURE_HAR=false

# Optional: HTTP proxy (socks5://user:pass@host:port or http://host:port)
PROXY_URL=
